# ============================================================
# Alpha Center / alphaTrack — Variables d'environnement (modèle)
# Copier vers .env (jamais versionné). Ne PAS commiter de vraies valeurs.
# ============================================================

# Supabase — Projet (Cloud ou local)
# Local (supabase start) : http://127.0.0.1:54321
# Cloud : https://<ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Clé anonyme — exposable côté front (RLS protège tout)
SUPABASE_ANON_KEY=

# Clé service role — JAMAIS en front, uniquement en Edge Functions ou scripts admin locaux
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — pour signer les JWT custom des Edge Functions login-* en LOCAL.
# IMPORTANT : côté Supabase Cloud, ce secret est configuré sous le nom
# APP_JWT_SECRET (Supabase réserve le préfixe SUPABASE_ pour ses injections).
# Commande : pnpm exec supabase secrets set --project-ref <ref> APP_JWT_SECRET=<value>
SUPABASE_JWT_SECRET=

# Vite (front) — préfixées VITE_ pour être exposées au navigateur
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# URLs publiques des apps (utilisées pour CORS, redirections, liens dans PDFs)
VITE_ADMIN_URL=http://localhost:5173
VITE_PORTAIL_URL=http://localhost:5174
